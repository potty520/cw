<UserControl x:Class="FinanceApp.Views.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 快捷操作区 -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,20">
            <Button Content="&#xE700; 新增凭证" FontFamily="Segoe MDL2 Assets"
                   Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,10" Click="NewVoucher_Click"/>
            <Button Content="&#xE8FB; 凭证审核" FontFamily="Segoe MDL2 Assets"
                   Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,10"/>
            <Button Content="&#xE787; 凭证过账" FontFamily="Segoe MDL2 Assets"
                   Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,10"/>
            <Button Content="&#xE9F9; 资产负债表" FontFamily="Segoe MDL2 Assets"
                   Style="{StaticResource SuccessButtonStyle}" Margin="0,0,10,10"/>
            <Button Content="&#xE9F9; 利润表" FontFamily="Segoe MDL2 Assets"
                   Style="{StaticResource SuccessButtonStyle}" Margin="0,0,10,10"/>
        </WrapPanel>

        <!-- 概览卡片区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 今日凭证 -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="今日凭证" Style="{StaticResource SecondaryTextStyle}"/>
                    <TextBlock Text="12" FontSize="32" FontWeight="Bold" Foreground="#2563EB" Margin="0,10,0,5"/>
                    <TextBlock Text="张" Style="{StaticResource SecondaryTextStyle}"/>
                    <ProgressBar Value="70" Height="4" Foreground="#2563EB" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- 本月收入 -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="本月收入" Style="{StaticResource SecondaryTextStyle}"/>
                    <TextBlock Text="¥ 1,258,000" FontSize="24" FontWeight="Bold" Foreground="#10B981" Margin="0,10,0,5"/>
                    <TextBlock Text="+15.2%" Foreground="#10B981" Style="{StaticResource SecondaryTextStyle}"/>
                </StackPanel>
            </Border>

            <!-- 本月支出 -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="本月支出" Style="{StaticResource SecondaryTextStyle}"/>
                    <TextBlock Text="¥ 856,000" FontSize="24" FontWeight="Bold" Foreground="#EF4444" Margin="0,10,0,5"/>
                    <TextBlock Text="-8.5%" Foreground="#EF4444" Style="{StaticResource SecondaryTextStyle}"/>
                </StackPanel>
            </Border>

            <!-- 应收账款 -->
            <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="应收账款" Style="{StaticResource SecondaryTextStyle}"/>
                    <TextBlock Text="¥ 2,450,000" FontSize="24" FontWeight="Bold" Foreground="#F59E0B" Margin="0,10,0,5"/>
                    <TextBlock Text="12 笔未结算" Style="{StaticResource SecondaryTextStyle}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
