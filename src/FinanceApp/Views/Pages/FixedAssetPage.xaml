<UserControl x:Class="FinanceApp.Views.Pages.FixedAssetPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="新增资产" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0"/>
            <Button Content="计提折旧" Style="{StaticResource SuccessButtonStyle}" Margin="0,0,10,0"/>
            <Button Content="资产减少" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
            <Button Content="折旧记录" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
            <Button Content="刷新" Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>

        <!-- 资产列表 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 查询条件 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="资产状态：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox Width="120" SelectedIndex="0">
                        <ComboBoxItem Content="全部"/>
                        <ComboBoxItem Content="正常使用"/>
                        <ComboBoxItem Content="已提足折旧"/>
                        <ComboBoxItem Content="已处置"/>
                    </ComboBox>
                    <TextBlock Text="资产类别：" VerticalAlignment="Center" Margin="20,0,10,0"/>
                    <ComboBox Width="120" SelectedIndex="0">
                        <ComboBoxItem Content="全部"/>
                        <ComboBoxItem Content="房屋建筑"/>
                        <ComboBoxItem Content="运输设备"/>
                        <ComboBoxItem Content="电子设备"/>
                    </ComboBox>
                </StackPanel>

                <!-- 资产数据 -->
                <DataGrid x:Name="dgAssets" Grid.Row="1" AutoGenerateColumns="False"
                         CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="资产编号" Binding="{Binding AssetCode}" Width="100"/>
                        <DataGridTextColumn Header="资产名称" Binding="{Binding AssetName}" Width="*"/>
                        <DataGridTextColumn Header="类别" Binding="{Binding Category}" Width="100"/>
                        <DataGridTextColumn Header="原值" Binding="{Binding OriginalValue, StringFormat=N2}" Width="120"/>
                        <DataGridTextColumn Header="累计折旧" Binding="{Binding AccumulatedDepreciation, StringFormat=N2}" Width="120"/>
                        <DataGridTextColumn Header="净值" Binding="{Binding NetValue, StringFormat=N2}" Width="120"/>
                        <DataGridTextColumn Header="使用状态" Binding="{Binding Status}" Width="100"/>
                        <DataGridTextColumn Header="购置日期" Binding="{Binding PurchaseDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 汇总信息 -->
                <Border Grid.Row="2" Background="#F1F5F9" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="资产数量" Foreground="#64748B"/>
                            <TextBlock Text="25" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="资产原值合计" Foreground="#64748B"/>
                            <TextBlock Text="¥ 2,580,000.00" FontSize="18" FontWeight="Bold" Foreground="#2563EB"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="累计折旧合计" Foreground="#64748B"/>
                            <TextBlock Text="¥ 580,000.00" FontSize="18" FontWeight="Bold" Foreground="#F59E0B"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3">
                            <TextBlock Text="资产净值合计" Foreground="#64748B"/>
                            <TextBlock Text="¥ 2,000,000.00" FontSize="18" FontWeight="Bold" Foreground="#10B981"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
