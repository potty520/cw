<UserControl x:Class="FinanceApp.Views.Pages.VoucherPrintPreview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0" Background="White" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="打印" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0" Click="Print_Click"/>
                <Button Content="打印设置" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
                <Button Content="关闭" Style="{StaticResource SecondaryButtonStyle}" Click="Close_Click"/>
            </StackPanel>
        </Border>

        <!-- 凭证预览 -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Grid Margin="20">
                    <!-- 凭证内容 -->
                    <Grid x:Name="VoucherPrintContent" Width="700" MinHeight="400">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 标题 -->
                        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <TextBlock x:Name="txtCompanyName" Text="财智星财务软件" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="txtVoucherTitle" Text="记 账 凭 证" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- 凭证信息 -->
                        <Grid Grid.Row="1" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="凭证字：" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtVoucherWord" Text="记" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="凭证号：" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtVoucherNumber" Text="" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="日期：" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtVoucherDate" Text="" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- 分录表头 -->
                        <Border Grid.Row="2" BorderBrush="Black" BorderThickness="1,1,1,0" Background="#F1F5F9">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="摘要" FontWeight="Bold" Padding="5" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="科目代码" FontWeight="Bold" Padding="5" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="科目名称" FontWeight="Bold" Padding="5" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="借方金额" FontWeight="Bold" Padding="5" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="贷方金额" FontWeight="Bold" Padding="5" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- 分录内容 -->
                        <ItemsControl x:Name="EntriesControl" Grid.Row="3" BorderBrush="Black" BorderThickness="1,0,1,1">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                                            <TextBlock Text="{Binding Summary}" Padding="5"/>
                                        </Border>
                                        <Border Grid.Column="1" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                                            <TextBlock Text="{Binding AccountSubjectCode}" Padding="5" TextAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="2" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                                            <TextBlock Text="{Binding AccountSubjectName}" Padding="5"/>
                                        </Border>
                                        <Border Grid.Column="3" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                                            <TextBlock Text="{Binding DebitAmount, StringFormat=N2}" Padding="5" TextAlignment="Right"/>
                                        </Border>
                                        <TextBlock Grid.Column="4" Text="{Binding CreditAmount, StringFormat=N2}" Padding="5" TextAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 合计和签名 -->
                        <Grid Grid.Row="4" Margin="0,15,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 合计 -->
                            <Border Grid.Row="0" BorderBrush="Black" BorderThickness="1" Background="#F1F5F9">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="320"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                                        <TextBlock Text="合计" FontWeight="Bold" Padding="5" HorizontalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="1" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                                        <TextBlock Text=""/>
                                    </Border>
                                    <Border Grid.Column="2" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                                        <TextBlock Text=""/>
                                    </Border>
                                    <Border Grid.Column="3" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                                        <TextBlock x:Name="txtTotalDebit" Text="0.00" FontWeight="Bold" Padding="5" TextAlignment="Right"/>
                                    </Border>
                                    <TextBlock x:Name="txtTotalCredit" Text="0.00" Grid.Column="4" FontWeight="Bold" Padding="5" TextAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- 签名区 -->
                            <Grid Grid.Row="1" Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="主管：" />
                                    <TextBlock Height="20"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="复核：" />
                                    <TextBlock Height="20"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="记账：" />
                                    <TextBlock Height="20"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="制单：" />
                                    <TextBlock x:Name="txtCreator" Height="20"/>
                                </StackPanel>
                            </Grid>

                            <!-- 附件信息 -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,20,0,0">
                                <TextBlock Text="附件张数：" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtAttachmentCount" Text="0" Width="30" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="White" Padding="10" Margin="0,10,0,0">
            <TextBlock x:Name="txtStatus" Text="就绪" Foreground="#64748B"/>
        </Border>
    </Grid>
</UserControl>
