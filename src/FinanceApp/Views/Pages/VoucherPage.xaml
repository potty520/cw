<UserControl x:Class="FinanceApp.Views.Pages.VoucherPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="btnNew" Content="新增凭证" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0" Click="NewVoucher_Click"/>
            <Button x:Name="btnSave" Content="保存" Style="{StaticResource SuccessButtonStyle}" Margin="0,0,10,0" Click="SaveVoucher_Click"/>
            <Button x:Name="btnAudit" Content="审核" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Click="AuditVoucher_Click"/>
            <Button x:Name="btnPost" Content="过账" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Click="PostVoucher_Click"/>
            <Button x:Name="btnDelete" Content="删除" Style="{StaticResource DangerButtonStyle}" Margin="0,0,10,0" Click="DeleteVoucher_Click"/>
            <Button x:Name="btnPrint" Content="打印" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Click="PrintVoucher_Click"/>
            <Button Content="刷新" Style="{StaticResource SecondaryButtonStyle}" Click="Refresh_Click"/>
        </StackPanel>

        <!-- 凭证列表和编辑区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 凭证列表 -->
            <Border Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F1F5F9" CornerRadius="8,8,0,0" Padding="10">
                        <TextBlock Text="凭证列表" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>
                    <ListBox x:Name="lstVouchers" Grid.Row="1" BorderThickness="0" SelectionChanged="LstVouchers_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding VoucherNumber}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding VoucherDate, StringFormat='{}{0:yyyy-MM-dd}'}" Foreground="#64748B" FontSize="12"/>
                                    <TextBlock Text="{Binding VoucherStatus}" Foreground="#2563EB" FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 凭证编辑区 -->
            <Border Grid.Column="1" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 凭证头 -->
                    <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="8,8,0,0" Padding="15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="凭证字：" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <ComboBox x:Name="cboVoucherWord" Width="80" SelectedIndex="0">
                                    <ComboBoxItem Content="记"/>
                                    <ComboBoxItem Content="收"/>
                                    <ComboBoxItem Content="付"/>
                                    <ComboBoxItem Content="转"/>
                                </ComboBox>
                                <TextBlock Text="凭证号：" VerticalAlignment="Center" Margin="20,0,5,0"/>
                                <TextBox x:Name="txtVoucherNumber" Width="120" IsReadOnly="True" Background="#F1F5F9"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <TextBlock Text="日期：" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <DatePicker x:Name="dtpVoucherDate" Width="120"/>
                                <TextBlock Text="附件数：" VerticalAlignment="Center" Margin="20,0,5,0"/>
                                <TextBox x:Name="txtAttachmentCount" Width="50" Text="0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 凭证分录 -->
                    <DataGrid x:Name="dgEntries" Grid.Row="1" AutoGenerateColumns="False"
                             CanUserAddRows="False" HeadersVisibility="Column"
                             GridLinesVisibility="Horizontal" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="摘要" Binding="{Binding Summary}" Width="200"/>
                            <DataGridTextColumn Header="科目编码" Binding="{Binding AccountSubjectCode}" Width="100"/>
                            <DataGridTextColumn Header="科目名称" Binding="{Binding AccountSubjectName}" Width="*"/>
                            <DataGridTextColumn Header="借方金额" Binding="{Binding DebitAmount, StringFormat=N2}" Width="120"/>
                            <DataGridTextColumn Header="贷方金额" Binding="{Binding CreditAmount, StringFormat=N2}" Width="120"/>
                            <DataGridTextColumn Header="数量" Binding="{Binding Quantity}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- 凭证尾 -->
                    <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,8,8" Padding="15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txtMemo" Text="备注：" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="借方合计：" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock x:Name="txtTotalDebit" Text="0.00" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                <TextBlock Text="贷方合计：" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock x:Name="txtTotalCredit" Text="0.00" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
