<UserControl x:Class="FinanceApp.Views.Pages.ReportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 查询条件 -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="报表类型：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="cboReportType" Width="150" SelectedIndex="0" Margin="0,0,20,0">
                    <ComboBoxItem Content="资产负债表"/>
                    <ComboBoxItem Content="利润表"/>
                    <ComboBoxItem Content="现金流量表"/>
                    <ComboBoxItem Content="科目余额表"/>
                </ComboBox>

                <TextBlock Text="会计期间：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="cboYear" Width="80" SelectedIndex="2" Margin="0,0,5,0">
                    <ComboBoxItem Content="2024"/>
                    <ComboBoxItem Content="2025"/>
                    <ComboBoxItem Content="2026"/>
                </ComboBox>
                <TextBlock Text="年" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="cboMonth" Width="60" SelectedIndex="5">
                    <ComboBoxItem Content="1"/>
                    <ComboBoxItem Content="2"/>
                    <ComboBoxItem Content="3"/>
                    <ComboBoxItem Content="4"/>
                    <ComboBoxItem Content="5"/>
                    <ComboBoxItem Content="6"/>
                    <ComboBoxItem Content="7"/>
                    <ComboBoxItem Content="8"/>
                    <ComboBoxItem Content="9"/>
                    <ComboBoxItem Content="10"/>
                    <ComboBoxItem Content="11"/>
                    <ComboBoxItem Content="12"/>
                </ComboBox>

                <Button Content="查询报表" Style="{StaticResource PrimaryButtonStyle}" Margin="20,0,10,0" Click="QueryReport_Click"/>
                <Button Content="打印" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
                <Button Content="导出Excel" Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- 报表内容 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 报表头 -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,20">
                    <TextBlock x:Name="txtReportTitle" Text="资产负债表" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtReportPeriod" Text="2026年6月" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- 报表数据 -->
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左列标题 -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="资产" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="年初数" FontWeight="Bold" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="期末数" FontWeight="Bold" TextAlignment="Center"/>
                        <StackPanel Grid.Column="3">
                            <TextBlock Text="负债和所有者权益" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        </StackPanel>
                        <TextBlock Grid.Column="4" Text="年初数" FontWeight="Bold" TextAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="期末数" FontWeight="Bold" TextAlignment="Center"/>

                        <!-- 报表行 -->
                        <StackPanel x:Name="ReportRowsPanel" Grid.ColumnSpan="6" Margin="0,40,0,0"/>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
