<Window x:Class="FinanceApp.Views.VoucherPrintWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pages="clr-namespace:FinanceApp.Views.Pages"
        Title="凭证打印预览"
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0" Background="White" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="打印设置" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Click="PrintSettings_Click"/>
                <Button Content="FastReport预览" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0" Click="PrintDirect_Click"/>
                <Button Content="导出PDF" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Click="ExportPdf_Click"/>
            </StackPanel>
        </Border>

        <!-- 原生预览 -->
        <pages:VoucherPrintPreview Grid.Row="1" x:Name="PrintPreview"/>
    </Grid>
</Window>
