<Window x:Class="FinanceApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="财智星财务软件"
        Height="768" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- 顶部导航栏 -->
        <Border Grid.Row="0" Background="#2563EB">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="财智星财务软件" FontSize="20" FontWeight="Bold"
                              Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 菜单按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="btnHome" Content="首页"
                           Background="Transparent" Foreground="White" Margin="4,0" Click="Navigate_Click" Tag="home" Padding="12,8" BorderThickness="0"/>
                    <Button x:Name="btnVoucher" Content="凭证管理"
                           Background="Transparent" Foreground="White" Margin="4,0" Click="Navigate_Click" Tag="voucher" Padding="12,8" BorderThickness="0"/>
                    <Button x:Name="btnLedger" Content="账簿查询"
                           Background="Transparent" Foreground="White" Margin="4,0" Click="Navigate_Click" Tag="ledger" Padding="12,8" BorderThickness="0"/>
                    <Button x:Name="btnReport" Content="报表中心"
                           Background="Transparent" Foreground="White" Margin="4,0" Click="Navigate_Click" Tag="report" Padding="12,8" BorderThickness="0"/>
                    <Button x:Name="btnFixedAsset" Content="固定资产"
                           Background="Transparent" Foreground="White" Margin="4,0" Click="Navigate_Click" Tag="fixedasset" Padding="12,8" BorderThickness="0"/>
                    <Button x:Name="btnSalary" Content="工资管理"
                           Background="Transparent" Foreground="White" Margin="4,0" Click="Navigate_Click" Tag="salary" Padding="12,8" BorderThickness="0"/>
                </StackPanel>

                <!-- 用户信息 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="txtUserInfo" Text="管理员" Foreground="White"
                              VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button Content="退出" Background="Transparent" Foreground="White"
                           BorderThickness="0" Cursor="Hand" Click="Logout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧菜单 -->
            <Border Grid.Column="0" Background="White" CornerRadius="8"
                   BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,10,0">
                <StackPanel x:Name="SideMenuPanel" Margin="10">
                    <TextBlock Text="快捷操作" FontSize="14" FontWeight="SemiBold"
                              Foreground="#1E293B" Margin="10,10,10,15"/>
                </StackPanel>
            </Border>

            <!-- 右侧内容区 -->
            <Border Grid.Column="1" Background="White" CornerRadius="8"
                   BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 内容标题 -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock x:Name="txtContentTitle" Text="欢迎使用" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock x:Name="txtPeriodInfo" Text="当前会计期间：2026年第6期" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- 内容区域 -->
                    <ContentControl x:Name="MainContent" Grid.Row="1"/>
                </Grid>
            </Border>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtStatus" Text="就绪" Foreground="#64748B" VerticalAlignment="Center" FontSize="12"/>
                <TextBlock Grid.Column="1" Text="{Binding CurrentPeriodYear, StringFormat='{}{0}年'}" Foreground="#64748B" VerticalAlignment="Center" FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>
