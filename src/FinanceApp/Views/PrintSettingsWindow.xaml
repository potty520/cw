<Window x:Class="FinanceApp.Views.PrintSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="打印设置"
        Height="500" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="打印设置" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- 设置内容 -->
        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- 纸张设置 -->
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="纸张设置" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="纸张大小：" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cboPaperSize" Grid.Column="1" SelectedIndex="0">
                                <ComboBoxItem Content="A4 (210×297mm)"/>
                                <ComboBoxItem Content="A5 (148×210mm)"/>
                                <ComboBoxItem Content="Letter (8.5×11in)"/>
                                <ComboBoxItem Content="自定义"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="纸张宽度：" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtPaperWidth" Grid.Column="1" Text="210" Width="80" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="纸张高度：" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtPaperHeight" Grid.Column="1" Text="297" Width="80" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="纸张方向：" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <RadioButton x:Name="rbPortrait" Content="纵向" IsChecked="True" Margin="0,0,20,0"/>
                                <RadioButton x:Name="rbLandscape" Content="横向"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="左边距：" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtMarginLeft" Grid.Column="1" Text="20" Width="60" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="右边距：" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtMarginRight" Grid.Column="1" Text="20" Width="60" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="上边距：" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtMarginTop" Grid.Column="1" Text="20" Width="60" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="下边距：" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtMarginBottom" Grid.Column="1" Text="20" Width="60" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 套打设置 -->
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="套打设置（预印表单）" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                        <CheckBox x:Name="chkEnableTaoDa" Content="启用套打模式" Margin="0,0,0,10" Checked="ChkTaoDa_Changed" Unchecked="ChkTaoDa_Changed"/>

                        <TextBlock Text="套打模式下，仅打印内容区域，不打印边框线" Foreground="#64748B" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>

                        <!-- 套打偏移量 -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="内容偏移X：" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtTaoDaOffsetX" Grid.Column="1" Text="0" Width="60" HorizontalAlignment="Left" IsEnabled="False"/>
                            <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="内容偏移Y：" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtTaoDaOffsetY" Grid.Column="1" Text="0" Width="60" HorizontalAlignment="Left" IsEnabled="False"/>
                            <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </Grid>

                        <Button x:Name="btnCalibrate" Content="校准套打位置" IsEnabled="False" Style="{StaticResource SecondaryButtonStyle}" Click="BtnCalibrate_Click" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- 打印机设置 -->
                <Border Background="White" CornerRadius="8" Padding="15" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="打印机设置" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="选择打印机：" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cboPrinter" Grid.Column="1"/>
                        </Grid>

                        <CheckBox x:Name="chkDefaultPrinter" Content="设为默认打印机" IsChecked="True"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="确定" Style="{StaticResource PrimaryButtonStyle}" Width="80" Margin="0,0,10,0" Click="BtnOK_Click"/>
            <Button Content="取消" Style="{StaticResource SecondaryButtonStyle}" Width="80" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
